{
  "name": "python-dependencies-manager",
  "displayName": "Python Dependencies Manager",
  "description": "Gerencia a .venv do projeto com pip: detecta requirements.txt, cria o ambiente se faltar, instala dependências e lista/instala/desinstala/atualiza pacotes — no estilo do gerenciador do PyCharm.",
  "version": "1.1.0",
  "publisher": "davisilvarafacho",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/davisilvarafacho/python-dependencies-manager.git"
  },
  "homepage": "https://github.com/davisilvarafacho/python-dependencies-manager#readme",
  "bugs": {
    "url": "https://github.com/davisilvarafacho/python-dependencies-manager/issues"
  },
  "engines": {
    "vscode": "^1.106.1"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "python",
    "pip",
    "uv",
    "venv",
    "requirements",
    "dependencies",
    "packages"
  ],
  "extensionDependencies": [
    "ms-python.python"
  ],
  "activationEvents": [
    "workspaceContains:requirements.txt",
    "workspaceContains:pyproject.toml",
    "workspaceContains:.venv",
    "onView:pythonDependenciesManager.packages",
    "onCommand:pythonDependenciesManager.installFromRequirements",
    "onCommand:pythonDependenciesManager.syncDependencies",
    "onCommand:pythonDependenciesManager.refreshPackages",
    "onCommand:pythonDependenciesManager.installPackage",
    "onCommand:pythonDependenciesManager.uninstallPackage",
    "onCommand:pythonDependenciesManager.updatePackage"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pythonDependenciesManager",
          "title": "Python Dependencies",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "pythonDependenciesManager": [
        {
          "type": "webview",
          "id": "pythonDependenciesManager.packages",
          "name": "Packages",
          "contextualTitle": "Python packages (.venv)"
        }
      ]
    },
    "commands": [
      {
        "command": "pythonDependenciesManager.installFromRequirements",
        "title": "Install from requirements.txt",
        "category": "Python Dependencies",
        "icon": "$(cloud-download)"
      },
      {
        "command": "pythonDependenciesManager.syncDependencies",
        "title": "Sync dependencies",
        "category": "Python Dependencies",
        "icon": "$(sync)"
      },
      {
        "command": "pythonDependenciesManager.refreshPackages",
        "title": "Refresh Packages",
        "category": "Python Dependencies",
        "icon": "$(refresh)"
      },
      {
        "command": "pythonDependenciesManager.installPackage",
        "title": "Install Package",
        "category": "Python Dependencies",
        "icon": "$(add)"
      },
      {
        "command": "pythonDependenciesManager.uninstallPackage",
        "title": "Uninstall Package",
        "category": "Python Dependencies",
        "icon": "$(trash)"
      },
      {
        "command": "pythonDependenciesManager.updatePackage",
        "title": "Update Package",
        "category": "Python Dependencies",
        "icon": "$(arrow-up)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "pythonDependenciesManager.refreshPackages",
          "when": "view == pythonDependenciesManager.packages",
          "group": "navigation@1"
        },
        {
          "command": "pythonDependenciesManager.installPackage",
          "when": "view == pythonDependenciesManager.packages",
          "group": "navigation@2"
        },
        {
          "command": "pythonDependenciesManager.installFromRequirements",
          "when": "view == pythonDependenciesManager.packages && !pythonDependenciesManager.isUv",
          "group": "navigation@3"
        },
        {
          "command": "pythonDependenciesManager.syncDependencies",
          "when": "view == pythonDependenciesManager.packages && pythonDependenciesManager.isUv",
          "group": "navigation@3"
        }
      ],
      "commandPalette": [
        {
          "command": "pythonDependenciesManager.installFromRequirements",
          "when": "!pythonDependenciesManager.isUv"
        },
        {
          "command": "pythonDependenciesManager.syncDependencies",
          "when": "pythonDependenciesManager.isUv"
        },
        {
          "command": "pythonDependenciesManager.uninstallPackage",
          "when": "false"
        },
        {
          "command": "pythonDependenciesManager.updatePackage",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.106.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.46.3",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
